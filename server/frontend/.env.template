# Copy this file to .env.local before starting the frontend.
# Use the exact browser-facing origins here. If you open the UI from another device,
# do not leave these values on localhost.

NEXTAUTH_URL=https://termviewer.local
NEXTAUTH_SECRET=replace-with-a-long-random-secret

NEXT_PUBLIC_BACKEND_URL=https://termviewer.local

KEYCLOAK_ISSUER=https://sso.termviewer.local/realms/termviewer
KEYCLOAK_CLIENT_ID=termviewer-app
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_ROLE=termviewer-admin
