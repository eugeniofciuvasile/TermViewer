# Copy this file to .env before running the backend.
# The backend auto-loads .env from server/backend when it starts.

APP_ADDR=:3001

# Prefer DATABASE_URL in production. If it is empty, the DB_* values below are used.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=keycloak
DB_PASSWORD=password
DB_NAME=termviewer
# DB_SSLMODE should be 'require', 'verify-ca', or 'verify-full' for encrypted connections in production.
DB_SSLMODE=disable

# KC_URL should point to the same Keycloak instance that issues browser tokens.
KC_URL=http://localhost:8081
KC_REALM=termviewer
KC_ADMIN_USER=admin
KC_ADMIN_PASS=admin
KC_CLIENT_ID=admin-cli
KC_CLIENT_SECRET=
KC_APP_CLIENT_ID=termviewer-app
KC_ADMIN_ROLE=termviewer-admin

# FRONTEND_BASE_URL and CORS_ALLOWED_ORIGINS should match the frontend NEXTAUTH_URL origin.
FRONTEND_BASE_URL=https://termviewer.local
CORS_ALLOWED_ORIGINS=https://termviewer.local
