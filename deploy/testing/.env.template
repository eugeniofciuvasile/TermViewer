# =========================================================================
# TermViewer Unified Configuration Template (Testing Environment)
# =========================================================================
# Copy this file to .env in the same directory before running docker-compose.
# This environment uses self-signed certificates for https://termviewer.local

# --- Environment Toggle ---
# Use 'localhost' for local-only testing.
# Use 'termviewer.local' (or your-hostname.local) for network/mobile testing.
TESTING_DOMAIN=termviewer.local
TESTING_SSO_DOMAIN=sso.termviewer.local
TESTING_LOGS_DOMAIN=logs.termviewer.local

# --- Database (PostgreSQL) ---
POSTGRES_BOOTSTRAP_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=password
POSTGRES_APP_DB=termviewer

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Browser-facing URL for Keycloak
KEYCLOAK_HOSTNAME=sso.termviewer.local

# --- Backend (Go) ---
# Keycloak realm name
KC_REALM=termviewer
# Admin role name in Keycloak
KC_ADMIN_ROLE=termviewer-admin

# --- Frontend (Next.js) ---
# Must be a long random string for NextAuth session encryption
NEXTAUTH_SECRET=replace-with-a-long-random-secret
# The browser-facing URL of your frontend
NEXTAUTH_URL=https://termviewer.local
# The base URL used for email links (activation, etc.)
FRONTEND_BASE_URL=https://termviewer.local
# The browser-facing URL of your backend API
NEXT_PUBLIC_API_URL=https://termviewer.local

# --- TLS Security ---
# Leave empty for Let's Encrypt. 
# For self-signed, put the SHA-256 fingerprint here to enable TOFU in the app.
SERVER_TLS_FINGERPRINT=

# --- SMTP (Email - e.g. Resend) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your_resend_api_key_here
SMTP_FROM=onboarding@resend.dev
