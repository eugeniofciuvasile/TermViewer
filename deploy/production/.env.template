# =========================================================================
# TermViewer Unified Configuration Template (Production Environment)
# =========================================================================
# Copy this file to .env in the same directory before running docker-compose.
# Replace all 'yourdomain.com' and passwords below!

# --- Domain Configuration ---
DOMAIN=yourdomain.com
ACME_EMAIL=your-email@example.com

# --- Database (PostgreSQL) ---
POSTGRES_BOOTSTRAP_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=generate-a-strong-password
POSTGRES_APP_DB=termviewer

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=generate-a-strong-password
# Browser-facing URL for Keycloak
KEYCLOAK_HOSTNAME=auth.yourdomain.com

# --- Backend (Go) ---
# Keycloak realm name
KC_REALM=termviewer
# Admin role name in Keycloak
KC_ADMIN_ROLE=termviewer-admin

# --- Frontend (Next.js) ---
# Must be a long random string for NextAuth session encryption
NEXTAUTH_SECRET=generate-a-long-random-secret-here
# The browser-facing URL of your frontend
NEXTAUTH_URL=https://yourdomain.com
# The base URL used for email links (activation, etc.)
FRONTEND_BASE_URL=https://yourdomain.com
# The browser-facing URL of your backend API
NEXT_PUBLIC_API_URL=https://yourdomain.com

# --- SMTP (Email - Resend) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your_resend_api_key_here
SMTP_FROM=hello@yourdomain.com

